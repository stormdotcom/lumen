{
  "name": "lumen-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Lumen — repository insight tools (CLI + Electron desktop app).",
  "license": "MIT",
  "workspaces": [
    "core",
    "cli",
    "desktop"
  ],
  "scripts": {
    "build:core": "npm run build --workspace=core",
    "build:cli": "npm run build --workspace=cli",
    "build:desktop": "npm run build --workspace=desktop",
    "build": "npm run build:core && npm run build:cli && npm run build:desktop",
    "cli": "node cli/dist/index.js",
    "desktop": "npm run start --workspace=desktop",
    "clean": "node -e \"const fs=require('fs');for(const p of ['core/dist','cli/dist','desktop/dist'])fs.rmSync(p,{recursive:true,force:true});\""
  },
  "engines": {
    "node": ">=18"
  }
}
