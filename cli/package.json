{
  "name": "lumen",
  "version": "0.1.0",
  "description": "Scan a repository and emit a self-contained HTML insight report.",
  "license": "MIT",
  "bin": {
    "lumen": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@lumen/core": "0.1.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
