{
  "name": "@ajmal_n/lumen-cli",
  "version": "0.5.0",
  "description": "Scan any repo and emit a self-contained HTML or Markdown report — with test-coverage breakdown, an interactive menu, and optional local-Ollama AI analysis.",
  "license": "MIT",
  "bin": {
    "lumen": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@ajmal_n/lumen-cli": "^0.5.0",
    "@ajmal_n/lumen-core": "0.5.0",
    "@clack/prompts": "^0.11.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
